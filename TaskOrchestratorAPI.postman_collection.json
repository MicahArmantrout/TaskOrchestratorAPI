            },
            "url": {
              "raw": "{{baseUrl}}/api/task",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "task"
              ]
            },
            "description": "Verifies a bearer token is required to create a task."
          },
          "response": []
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Verify Auth is working and that a task was created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "",
                  "    const task = pm.response.json();",
                  "    pm.expect(task).to.have.property(\"id\");",
                  "    pm.expect(task.id).to.be.ok;",
                  "",
                  "    pm.collectionVariables.set(\"taskId\", task.id);",
                  "    console.log(\"Created task id: \" + task.id);",
                  "    pm.expect(String(task.id)).to.eql(pm.collectionVariables.get(\"taskId\"));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Finish API work\",\n  \"isComplete\": false,\n  \"description\": \"Create a task from the HTTP file\",\n  \"status\": \"New\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/task",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "task"
              ]
            },
            "description": "Creates a task for the authenticated Google user. The API sets UserId from the bearer token."
          },
          "response": []
        },
        {
          "name": "Get Task By Id - Other User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Verify Users can't just grab any task\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{googleIdTokenForUser2}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/task/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "task",
                "{{taskId}}"
              ]
            },
            "description": "Verifies a different authenticated user cannot fetch another user's task."
          },
          "response": []
        },
        {
          "name": "Get All Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Verify you can get all tasks for a user\", function () {",
                  "    pm.response.to.have.status(200);",
                  "",
                  "    const tasks = pm.response.json();",
                  "    const taskId = pm.collectionVariables.get(\"taskId\");",
                  "",
                  "    pm.expect(tasks).to.be.an(\"array\");",
                  "    pm.expect(tasks.some(task => String(task.id) === taskId)).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/task",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "task"
              ]
            },
            "description": "Returns all tasks for the authenticated Google user."
          },
          "response": []
        },
