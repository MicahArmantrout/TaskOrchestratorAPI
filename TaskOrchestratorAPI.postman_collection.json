        {
          "name": "Edit Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Verify you can edit a task\", function () {",
                  "    pm.response.to.have.status(200);",
                  "",
                  "    const task = pm.response.json();",
                  "    pm.expect(String(task.id)).to.eql(pm.collectionVariables.get(\"taskId\"));",
                  "    pm.expect(task.title).to.eql(\"Updated task title\");",
                  "    pm.expect(task.isComplete).to.eql(true);",
                  "    pm.expect(task.description).to.eql(\"Updated from the HTTP file\");",
                  "    pm.expect(task.status).to.eql(\"Completed\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
